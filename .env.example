# Backend service (set these in Railway dashboard → backend service → Variables)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Frontend service (set these in Railway dashboard → frontend service → Variables)
# Set VITE_API_URL to the public URL Railway assigns to your backend service
VITE_API_URL=https://your-backend.up.railway.app
